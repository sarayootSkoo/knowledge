{
  "permissions": {
    "allow": [
      "Bash(node:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "docs",
    "kanban"
  ],
  "outputStyle": "Explanatory",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node projects/knowledge-graph/scripts/kanban-hook.mjs session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node projects/knowledge-graph/scripts/kanban-hook.mjs session-end"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node projects/knowledge-graph/scripts/kanban-hook.mjs file-changed"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node projects/knowledge-graph/scripts/kanban-hook.mjs agent-start"
          }
        ]
      }
    ]
  }
}
